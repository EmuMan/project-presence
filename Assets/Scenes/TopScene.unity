      value: AbilityTutorialDirector
      objectReference: {fileID: 0}
    - target: {fileID: 2424471378725654788, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: m_Name
      value: DialogueUI
      objectReference: {fileID: 0}
    - target: {fileID: 5803306295799944240, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: isDialogueActive
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 6348884089634201324, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: m_Name
      value: AbilityTutorialScript1
      objectReference: {fileID: 0}
    - target: {fileID: 6378508848691539592, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: dialogue.lines.Array.size
      value: 6
      objectReference: {fileID: 0}
    - target: {fileID: 6378508848691539592, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: dialogue.lines.Array.data[0].line
      value: "Wait what\u2019s with my hud? It\u2019s completely blank."
      objectReference: {fileID: 0}
    - target: {fileID: 6378508848691539592, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: dialogue.lines.Array.data[1].line
      value: "We\u2019re on a remote planet shipping countless telepresence hosts
        across the universe, each costing millions of credits to manufacture and
        send out."
      objectReference: {fileID: 0}
    - target: {fileID: 6378508848691539592, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: dialogue.lines.Array.data[2].line
      value: 'You think you would have every bell and whistle available to you? '
      objectReference: {fileID: 0}
    - target: {fileID: 6378508848691539592, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: dialogue.lines.Array.data[3].line
      value: Well... huh.
      objectReference: {fileID: 0}
    - target: {fileID: 6378508848691539592, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: dialogue.lines.Array.data[4].line
      value: "For now, we start from the basics again and rely on our training to
        build from there. For now, just choose what\u2019s available and deploy."
      objectReference: {fileID: 0}
    - target: {fileID: 6378508848691539592, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: dialogue.lines.Array.data[5].line
      value: Fine fine.
      objectReference: {fileID: 0}
    - target: {fileID: 6378508848691539592, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: dialogue.lines.Array.data[0].character.name
      value: Trick
      objectReference: {fileID: 0}
    - target: {fileID: 6378508848691539592, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: dialogue.lines.Array.data[1].character.name
      value: Tor
      objectReference: {fileID: 0}
    - target: {fileID: 6378508848691539592, guid: b5eefe37216130042a6bef2647179636, type: 3}
      propertyPath: dialogue.lines.Array.data[2].character.name
